      "C": [{ "type": "paragraph", "text": "Selective IgA deficiency causes mucosal infections but does not explain thrombocytopenia." }]
    },
    "educationalObjective": [
      { "type": "paragraph", "text": "Recognize the classic triad of Wiskott-Aldrich syndrome." }
