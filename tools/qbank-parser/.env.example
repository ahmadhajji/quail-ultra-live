# QBank Parser configuration
# Copy to .env and update values for your environment.

# Required: OpenAI API key (extraction + USMLE formatting)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: formatter/extraction tuning
OPENAI_EXTRACTION_MODEL=gpt-5.4-mini
OPENAI_FORMATTER_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=high
OPENAI_WEB_SEARCH=false
OPENAI_FACT_CHECK_MODEL=gpt-5.4
OPENAI_FACT_CHECK_REASONING_EFFORT=high
OPENAI_ESCALATION_MODEL=gpt-5.5
OPENAI_ESCALATION_REASONING_EFFORT=xhigh
OPENAI_ESCALATION_CONFIDENCE_THRESHOLD=70
OPENAI_TARGET_RPM=450
OPENAI_MAX_INFLIGHT=120

# Optional: explicit default formatter provider (only "openai" is supported)
FORMATTER_PROVIDER=openai

# Optional: Google Slides metadata integration
# URL format: https://docs.google.com/presentation/d/[THIS_IS_THE_ID]/edit
GOOGLE_SLIDES_ID=
GOOGLE_CREDENTIALS_PATH=credentials.json

# Optional: writable workspace override for packaged/desktop runs.
# Defaults to project root in source mode, or macOS app support directory in frozen mode.
QBANK_BASE_DIR=
