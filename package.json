{
  "name": "quail-ultra-live",
  "version": "0.1.0",
  "description": "Account-backed web fork of Quail Ultra with study-pack import, export, offline cache, and sync.",
  "main": "build/server/index.js",
  "scripts": {
    "build": "npm run build:frontend && npm run build:worker && npm run build:server",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "build:worker": "tsc --project tsconfig.worker.json",
    "build:server": "tsc --project tsconfig.server.json && rm -rf build/shared/native-contracts && cp -R shared/native-contracts build/shared/native-contracts",
    "start": "npm run build && node build/server/index.js",
    "start:railway": "node build/server/index.js",
    "start:server": "tsx server/index.ts",
    "dev": "concurrently \"vite build --watch --mode development --config frontend/vite.config.ts\" \"tsc --project tsconfig.worker.json --watch --preserveWatchOutput\" \"tsx watch --clear-screen=false server/index.ts\"",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:server && npm run typecheck:worker",
    "typecheck:frontend": "tsc --project tsconfig.json --noEmit",
    "typecheck:server": "tsc --project tsconfig.server.json --noEmit",
    "typecheck:worker": "tsc --project tsconfig.worker.json --noEmit",
    "validate:qbank": "tsx scripts/validate-qbank.ts",
    "parser:help": "python3 tools/qbank-parser/main.py --help",
    "parser:test": "cd tools/qbank-parser && pytest -q",
    "parser:extract": "python3 tools/qbank-parser/main.py",
    "parser:native": "python3 tools/qbank-parser/convert_to_quail.py --native",
    "migrate:cloud": "tsx scripts/migrate-to-cloud.ts",
    "migrate:railway": "tsx scripts/migrate-to-railway.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:smoke": "playwright test",
    "test:smoke:local": "npm run build && playwright test",
    "check": "npm run typecheck && npm run test"
  },
  "engines": {
    "node": "24.x"
  },
  "keywords": [
    "quail",
    "usmle",
    "study-pack"
  ],
  "author": "Ahmad Hajji",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.901.0",
    "@aws-sdk/s3-request-presigner": "^3.901.0",
    "@hashintel/refractive": "^0.0.3",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.3.3",
    "ajv": "^8.20.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "bootstrap": "^5.3.3",
    "cookie": "^1.1.1",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "fflate": "^0.8.2",
    "multer": "^1.4.5-lts.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "sanitize-html": "^2.17.0",
    "unzipper": "^0.12.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "jsdom": "^26.1.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
}
