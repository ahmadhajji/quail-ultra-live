{
  "name": "quail-ultra-live",
  "version": "0.1.0",
  "description": "Account-backed web fork of Quail Ultra with study-pack import, export, offline cache, and sync.",
  "main": "server/index.js",
  "scripts": {
    "build": "vite build --config frontend/vite.config.ts",
    "start": "npm run build && node server/index.js",
    "start:server": "node server/index.js",
    "dev": "concurrently \"vite build --watch --mode development --config frontend/vite.config.ts\" \"node --watch server/index.js\"",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:smoke": "playwright test",
    "check": "npm run build && npm run typecheck && node --check server/index.js && node --check shared/progress.js && node --check shared/qbank.js && npm run test"
  },
  "engines": {
    "node": "24.x"
  },
  "keywords": [
    "quail",
    "usmle",
    "react",
    "express",
    "study-pack"
  ],
  "author": "Ahmad Hajji",
  "license": "MIT",
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "bootstrap": "^4.6.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "jquery": "^3.6.0",
    "multer": "^1.4.5-lts.1",
    "popper.js": "^1.16.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sanitize-html": "^2.17.0",
    "unzipper": "^0.12.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
}
